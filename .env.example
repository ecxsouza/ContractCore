# ================================================================
# ContractCore — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA commite o arquivo .env.local no Git
# ================================================================

# ── SUPABASE ─────────────────────────────────────────────────────
# Encontre em: https://supabase.com/dashboard/project/SEU_PROJETO/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...sua_service_role_key_aqui

# ── ANTHROPIC / CLAUDE ────────────────────────────────────────────
# ⚠️  NUNCA exponha esta chave no frontend
# Encontre em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...sua_chave_aqui
# Modelo obrigatório em produção — sem esta variável a API retornará erro
# IDs canônicos confirmados na documentação Anthropic (junho 2026):
#   claude-sonnet-4-6          → recomendado — melhor custo-benefício ($3/$15 por MTok)
#   claude-opus-4-8            → mais capaz — raciocínio complexo ($5/$25 por MTok)
#   claude-haiku-4-5-20251001  → mais rápido e barato ($1/$5 por MTok)
# ATENÇÃO: claude-opus-4-6 está DEPRECIADO — use claude-opus-4-8
# Em produção (Vercel), esta variável é OBRIGATÓRIA.
# Em desenvolvimento, usa claude-sonnet-4-6 como fallback com aviso no console.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── NEXT.JS ───────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=gere_com_openssl_rand_base64_32

# ── APP ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ContractCore

# ── RATE LIMITING (opcional, recomendado em produção) ─────────────
# Upstash Redis para rate limiting das chamadas à IA
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── RESEND (E-mail) ───────────────────────────────────────────────
# Crie conta gratuita em https://resend.com
# Plano gratuito: 3.000 e-mails/mês
RESEND_API_KEY=re_...sua_chave_aqui
# Domínio de envio (pode usar onboarding@resend.dev no plano gratuito)
RESEND_FROM_EMAIL=ContractCore <onboarding@resend.dev>

# ── CRON (Vercel Cron Jobs) ───────────────────────────────────────
# Gere um segredo aleatório: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=gere_uma_string_aleatoria_aqui

# ── AMBIENTE ──────────────────────────────────────────────────────
NODE_ENV=development
